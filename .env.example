# Copy to .env and fill in the keys you need. All are OPTIONAL —
# Claude Code can also search the web directly. These keys make the
# news fetch reproducible (and re-usable inside the n8n routine).

# Tavily — news freshness endpoints (press synthesis)
# https://tavily.com
TAVILY_API_KEY=

# NewsAPI — fallback news source (press synthesis)
# https://newsapi.org
NEWSAPI_KEY=
